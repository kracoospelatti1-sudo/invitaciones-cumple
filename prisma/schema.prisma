generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Client {
  id          Int          @id @default(autoincrement())
  name        String
  contact     String?
  notes       String?      @db.Text
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  invitations Invitation[]

  @@map("clients")
}

model Invitation {
  id             Int               @id @default(autoincrement())
  clientId       Int
  title          String
  slug           String            @unique
  eventDate      DateTime
  location       String
  message        String?           @db.Text
  coverImageUrl  String?
  status         InvitationStatus  @default(DRAFT)
  hostViewToken  String            @unique
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  client         Client            @relation(fields: [clientId], references: [id], onDelete: Restrict)
  photos         InvitationPhoto[]
  quotes         InvitationQuote[]
  rsvps          Rsvp[]

  @@index([clientId])
  @@map("invitations")
}

model InvitationPhoto {
  id            Int        @id @default(autoincrement())
  invitationId  Int
  imageUrl      String
  sortOrder     Int        @default(0)
  createdAt     DateTime   @default(now())
  invitation    Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)

  @@index([invitationId])
  @@map("invitation_photos")
}

model InvitationQuote {
  id            Int        @id @default(autoincrement())
  invitationId  Int
  phrase        String     @db.Text
  sortOrder     Int        @default(0)
  createdAt     DateTime   @default(now())
  invitation    Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)

  @@index([invitationId])
  @@map("invitation_quotes")
}

model Rsvp {
  id             Int        @id @default(autoincrement())
  invitationId   Int
  attendeeName   String
  attendance     Attendance
  isCeliac       Boolean    @default(false)
  isVegan        Boolean    @default(false)
  isVegetarian   Boolean    @default(false)
  conditionOther String?    @db.Text
  comment        String?    @db.Text
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  invitation     Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)

  @@index([invitationId])
  @@index([attendance])
  @@map("rsvps")
}

enum InvitationStatus {
  DRAFT
  PUBLISHED
}

enum Attendance {
  YES
  NO
}
